# Supabase Postgres runtime connection.
# Use the Session Pooler for a long-running Express server when IPv4 support is needed.
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Optional: direct database URL for Drizzle schema pushes/migrations.
# Supabase direct connections require IPv6 unless your project has the IPv4 add-on.
DATABASE_DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# Optional pool size for the API server's node-postgres pool.
DATABASE_POOL_MAX="10"

# Browser-safe Supabase client settings.
# Do not put service_role or secret keys in VITE_* variables.
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<publishable-or-anon-key>"

# API server
PORT="5000"
